# ── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://evangadi-forum-frontend-eyg6.onrender.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Connection string for Supabase. Found in: Project Settings > Database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/postgres
DATABASE_URL=

# ── Supabase (Optional/Future Use) ───────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# ── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── RAG Settings ─────────────────────────────────────────────────────────────
RAG_UPLOAD_DIR=uploads/rag
RAG_MAX_UPLOAD_MB=10
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
