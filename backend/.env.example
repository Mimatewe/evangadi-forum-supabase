PORT=3777
CORS_ORIGIN=http://localhost:5173

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Connection string for Supabase. Found in: Project Settings > Database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/postgres
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres
# Optional: set to "false" to disable SSL (not recommended for Supabase).
DB_SSL=true

# Legacy MySQL variables (no longer used after Supabase migration):
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_NAME=evangadi_forum

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

RECOMMEND_THRESHOLD=0.75
RECOMMEND_K=5

RAG_UPLOAD_DIR=uploads/rag
RAG_MAX_UPLOAD_MB=10
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
RAG_MAX_CHUNKS_PER_DOC=200
RAG_MAX_PDFS_PER_USER=20
